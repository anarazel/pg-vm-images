ARG DEBIAN_RELEASE
ARG TAG_PREFIX
ARG DATE

FROM ${TAG_PREFIX}_${DEBIAN_RELEASE}_ci:${DATE}

LABEL \
  org.opencontainers.image.source="https://github.com/anarazel/pg-vm-images" \
  org.opencontainers.image.description="image for running postgres CI + docs"

ENV DEBIAN_FRONTEND=noninteractive

COPY /scripts/linux_debian_install_deps_docs.sh /scripts/

RUN \
  apt-get -y update && \
  apt-get -y upgrade && \
  /scripts/linux_debian_install_deps_docs.sh \
  rm /scripts/linux_debian_install_deps_docs.sh \
  apt-get clean && rm -rf /var/lib/apt/lists/*

ARG IMAGE_NAME

ENV IMAGE_IDENTITY=$IMAGE_NAME-$DATE
